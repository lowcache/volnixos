#!/usr/bin/env bash

set -euo pipefail

cleanup() {
    set +x
    # Kill background jobs (socat, waypipe)
    kill $(jobs -p) 2>/dev/null || true
    
    # Remove waypipe client socket
    rm -f /tmp/waypipe-client.sock
    
    # Remove iptables firewall rule if added
    if [[ -n "${container_ip-}" && -n "${PORT-}" ]]; then
        sudo iptables -D INPUT -p tcp -s "$container_ip" --dport "$PORT" -j ACCEPT 2>/dev/null || true
    fi
    
    # Lazy unmount the home directory if mounted to prevent locking files/mount leaks
    if [[ -n "${container_name-}" ]]; then
        mount_point="/var/lib/containers/$container_name/home/user"
        if mountpoint -q "$mount_point"; then
            sudo umount -l "$mount_point" 2>/dev/null || true
        fi
    fi
}

trap cleanup EXIT

repo="$( cd "$( dirname "${BASH_SOURCE[0]}" )" >/dev/null 2>&1 && pwd )/.."
flake="${SELF-$repo}"

container_name="${CONTAINER-kalinix}"
container_homedir="$HOME/kalinix/$container_name"

mkdir -p "$container_homedir"

if [[ "${CONNECTION-x}" == x ]]; then
    case "$XDG_SESSION_TYPE" in
        wayland) connection="wayland" ;;
        x11) connection="x11" ;;
        *) echo "Warning: unrecognized \$XDG_SESSION_TYPE $XDG_SESSION_TYPE and \$CONNECTION not set. Guessing x11"; connection=x11 ;;
    esac
else
    connection="${CONNECTION}"
fi

if [[ "$connection" == "wayland" ]]; then
    PORT=1337
    waypipe client & sleep 1
elif [[ "$connection" == "x11" ]]; then
    PORT=6000
else
    echo "Connection type $CONNECTION unsupported"
    exit 1
fi

if nixos-container list | grep '^'"$container_name"'$' > /dev/null; then
    set -x
    sudo nixos-container update --flake "${flake}" "$container_name"
else
    set -x
    sudo nixos-container create --flake "${flake}" "$container_name"
fi

sudo nixos-container start "$container_name"

# Resolve network configurations dynamically
host_ip=$(ip -4 -o addr show dev "ve-$container_name" | awk '{print $4}' | cut -d/ -f1)
container_ip=$(sudo nixos-container show-ip "$container_name")

if [[ -z "$host_ip" || -z "$container_ip" ]]; then
    echo "Error: Failed to resolve host or container IP for interface ve-$container_name"
    exit 1
fi

# Secure graphical listeners by binding only to the internal container bridge interface
if [[ "$connection" == "wayland" ]]; then
    socat TCP-LISTEN:1337,bind="$host_ip",reuseaddr,fork UNIX-CONNECT:/tmp/waypipe-client.sock &
elif [[ "$connection" == "x11" ]]; then
    socat TCP-LISTEN:6000,bind="$host_ip",reuseaddr,fork UNIX-CONNECT:/tmp/.X11-unix/X0 &
fi

# Add firewall exception restricted strictly to container's source IP
sudo iptables -I INPUT -p tcp -s "$container_ip" --dport "$PORT" -j ACCEPT

# Bind home directory
sudo mount -o rbind,uid=1000 "$container_homedir" "/var/lib/containers/$container_name/home/user"
set +x

if [[ "$connection" == "wayland" ]]; then
    set -x
    sudo machinectl -E XDG_SESSION_TYPE=wayland -E GDK_BACKEND=wayland -E QT_QPA_PLATFORM=wayland-egl shell --uid=user "$container_name" /run/current-system/sw/bin/waypipe --login-shell server "$@"
    set +x
elif [[ "$connection" == "x11" ]]; then
    set -x
    sudo machinectl copy-to "$container_name" "$HOME/.Xauthority" /home/user/.Xauthority-tmp
    sudo machinectl shell "$container_name" /run/current-system/sw/bin/mv /home/user/.Xauthority-tmp /home/user/.Xauthority
    sudo machinectl shell "$container_name" /run/current-system/sw/bin/chown user:users /home/user/.Xauthority
    sudo machinectl -E XDG_SESSION_TYPE=x11 -E GDK_BACKEND=x11 -E QT_QPA_PLATFORM=xcb shell --uid=user "$container_name"
    set +x
fi

set +x

