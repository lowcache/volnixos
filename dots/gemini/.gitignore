# Gemini / Antigravity local agent data.
# Patterns are relative to this dir (dots/gemini/). This controls git tracking only —
# files stay on disk and the live config is served via the out-of-store symlink + /persist.
# Keep declarative config (config/, skills/, settings.json, GEMINI.md, mcp_config.json);
# ignore runtime chaff and secrets (repo is PUBLIC).

# Secrets / per-install identity — never track
oauth_creds.json
google_accounts.json
state.json
installation_id

# Regenerable agent runtime data
brain/
mcp/
log/
logs/
cache/
tmp/
history/
*.log
